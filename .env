
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36
LangSearchAPI=sk-d839c46df26a4774a8b2e00d8adb3271

# ============ LangSmith ============
# 注意：.env 由 python-dotenv 解析，不要写 `export` 前缀，值也不要加引号
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=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
LANGSMITH_PROJECT=test
# ============ DASHSCOPE LLM ============
DASHSCOPE_API_KEY=sk-a42163d874e74c41923259805c86a453
DASHSCOPE_MODEL_NAME=qwen3.6-plus
DASHSCOPE_TEMPERATURE=0
# DASHSCOPE_BASE_URL 可选，不写走代码里的默认值
# ============ DeepSeek LLM ============
DEEPSEEK_API_KEY=sk-b2b390e2b3c641f6ac19d03760c29128
OPENAI_API_BASE=https://api.deepseek.com
MODEL_NAME=deepseek-chat
# LLM 采样温度
LLM_TEMPERATURE=0
# LLM provider 选择（chat.py get_llm + 未来 agent 入口）：deepseek / dashscope
LLM_PROVIDER=deepseek

# ============ Tavily ============
TAVILY_API_KEY=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


# ============ Redis（agent checkpointer） ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_CHECKPOINT_PREFIX=checkpoints
# 单位：分钟；与 refresh_on_read 配合，每次读写都重置倒计时
REDIS_CHECKPOINT_TTL_MINUTES=60


# ============ Chat API（/v1/chat/completions） ============
DEFAULT_MODEL=deepseek-chat
# 逗号分隔；暴露给 /v1/models 列表
KNOWN_MODELS=deepseek-chat,deepseek-reasoner


# ============ Logging ============
LOG_DIR=logs
# 单条文件最大字节数（100 MB）；超过则按天 + 按大小切割
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10
# thread_id 解析路径诊断日志级别；DEBUG 时打 header 详情（含敏感字段长度）
LOG_LEVEL_THREAD=DEBUG


# ============ Milvus（向量库） ============
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus

# ============ Embedding（Qwen text-embedding-v4） ============
EMBEDDING_API_KEY=sk-a42163d874e74c41923259805c86a453
EMBEDDING_BASE_URL=https://ws-oi8z1umy0fuyv6if.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_VECTOR_DIM=2048

# ============ RAG 切分 / 检索 ============
# 句群窗口：window=3 句、step=3 步进（无重叠）
RAG_CHUNK_WINDOW_SIZE=2
RAG_CHUNK_STEP=1
# sentence 集合 dense 检索 top-k
RAG_SEARCH_LIMIT=50
# 整篇 doc 字数阈值：<阈值返回整 doc，≥返回 top 2 chapters
RAG_CHAR_COUNT_THRESHOLD=200
# 父子查询最终返回的 document 数量上限
RAG_TOP_DOCS=3
# 长文档（≥字数阈值）时返回得分最高的 N 个 chapter
RAG_TOP_CHAPTERS=2
# rag_decomposed_search 工具拆分子查询的最大数量
RAG_MAX_SUBQUERIES=4
# HNSW 索引超参
RAG_INDEX_TYPE=HNSW
RAG_INDEX_HNSW_M=16
RAG_INDEX_HNSW_EF=500
# 集合一致性级别：Strong / Bounded / Eventually / Session
RAG_CONSISTENCY_LEVEL=Bounded
# 集合名（一起用动态字段，schema中未定义的字段可以自动存入动只是将态字段中）
RAG_CHAPTER_COLL=chapter_collection
RAG_SENTENCE_COLL=sentence_collection

# ============ Async 并发治理 ============
# 全局 LLM 并发上限（agent + task 直 LLM 路径共享）
LLM_MAX_CONCURRENCY=16
# Milvus 批量 insert 并发上限
MILVUS_INSERT_CONCURRENCY=4

# ============ Rate Limit（slowapi，每 IP / 分钟） ============
# ingest 是重操作（chunking + LLM contextualize + 大批量 insert），限速严
RATE_LIMIT_INGEST_PER_MIN=10
# 向量 / 全文检索中等频率
RATE_LIMIT_SEARCH_PER_MIN=60
# chat 流式（OpenWebUI 自身会并发，配额宽松）
RATE_LIMIT_CHAT_PER_MIN=120
RATE_LIMIT_DEFAULT_PER_MIN=240
# 多 pod 部署时改为 redis://... 共享计数；不写则用 in-memory（仅单 pod 准确）
RATE_LIMIT_REDIS_URI=redis://localhost:6379/1


# ============ RBAC（多租户 / app/auth/） ============
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/rbac?charset=utf8mb4
JWT_SECRET=ec7a2eebaf7801056dae85b223eba0ddb191b44d49918d768c437f6cb7b13ee1
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# dev 模式下 lifespan 自动 create_all；prod 用 alembic upgrade head
ENV=dev
